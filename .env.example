# Copy this file to .env and fill in your CF_Authorization cookie.
#
# How to get the cookie:
#   1. Go to https://chat.tamu.ai and sign in with TAMU SSO + Duo MFA
#   2. Open DevTools (F12) → Application tab → Cookies → https://chat.tamu.ai
#   3. Find CF_Authorization, copy its Value (starts with eyJ...)
#   4. Paste below as:  TAMU_CF_COOKIE=CF_Authorization=eyJ...
#
# The cookie expires every ~24 hours — repeat steps 1-4 each session.
# Do NOT commit .env to git. Do NOT share your cookie.

TAMU_CF_COOKIE=CF_Authorization=eyJ_PASTE_YOUR_COOKIE_VALUE_HERE

# Shared course API key (see TAMU API Setup Guide, Section 5)
TAMU_API_KEY=sk-PASTE_COURSE_API_KEY_HERE
